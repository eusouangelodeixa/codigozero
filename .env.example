# ── Código Zero — Backend Environment ──
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://czero:codigozero2026@localhost:5432/codigozero

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=cz-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Lojou Payment Gateway
LOJOU_API_KEY=your-lojou-api-key-here
LOJOU_API_URL=https://api.lojou.app
LOJOU_WEBHOOK_SECRET=your-webhook-secret-here
LOJOU_PLAN_ID=tbo8f
LOJOU_PRODUCT_PID=uoEHz
# Optional: numeric product id used to scope coupons via discount.product_ids.
# Leave empty to make coupons unrestricted.
LOJOU_PRODUCT_ID=
# Close Friends order bump pid (one_time, 1297 MZN, grants +2 months)
LOJOU_CLOSE_FRIENDS_PID=JQQWc

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Scraper
MAX_DAILY_SEARCHES=10

# ── Komunika embedded module (provision + SSO) ──
# Komunika is bundled free with the CZ subscription — every paying member is
# provisioned automatically on order.approved (no separate add-on).
# Base URL of the Komunika API (shared with the SDR outbound integration).
KOMUNIKA_API_URL=https://api.komunika.site
# Admin X-API-Key (kmnk_...) used for SDR outbound + system WhatsApp sends.
KOMUNIKA_ADMIN_API_KEY=
# SDR outbound agent ids (fallbacks for SystemConfig.komunika*AssistantId).
# Used by the remarketing cron to initiate outbound SDR calls instead of
# injecting leads into a funnel.
KOMUNIKA_SDR_VISITOR_ASSISTANT_ID=
KOMUNIKA_SDR_CHECKOUT_ASSISTANT_ID=
# Shared secrets — generate with: openssl rand -hex 64 (two DIFFERENT values).
# Must match CODIGO_ZERO_HMAC_SECRET / CODIGO_ZERO_JWT_SECRET on the Komunika side.
KOMUNIKA_HMAC_SECRET=
KOMUNIKA_SSO_JWT_SECRET=

# ── Resend (e-mail delivery of access credentials) ──
# Get an API key at resend.com and VERIFY your sending domain (e.g. czero.sbs).
# RESEND_FROM must use that verified domain. Empty key → e-mail sending no-ops.
RESEND_API_KEY=
RESEND_FROM=Código Zero <acesso@czero.sbs>
