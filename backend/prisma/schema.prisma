generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  name               String
  email              String           @unique
  phone              String           @unique
  passwordHash       String
  role               String           @default("member") // member, admin
  isActive           Boolean          @default(true)
  subscriptionStatus String           @default("active") // active, grace_period, overdue, canceled
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  renewalUrl         String?
  retentionCouponsUsed Int            @default(0)
  paymentsSinceLastCoupon Int         @default(0)
  lojouOrderId       String?
  checkoutUrl        String?
  lojouCustomerId    String?
  // Stripe identifiers. Populated by the Stripe webhook on first
  // payment / subscription creation. customerId is unique because
  // Stripe only ever creates one Customer per email-tier.
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  dailySearchCount   Int              @default(0)
  lastSearchDate     DateTime?
  komunikaApiKey     String?
  komunikaInstanceId String?
  remarketingStage   String           @default("none") // none → visitor_sent | none → checkout_pending → checkout_failed_sent
  surveyAnswers      Json?
  avatarUrl          String?
  hasCompletedOnboarding Boolean @default(false)
  lastExpirationAlert DateTime?

  // ── Close Friends (order bump JQQWc): grants +2 months on top of the
  // standard subscription, expires together with subscriptionEnd, and is
  // automatically dropped on a renewal payment that doesn't include the bump.
  closeFriends              Boolean   @default(false)
  closeFriendsUntil         DateTime?
  closeFriendsPurchaseCount Int       @default(0)

  // Set when the admin grants a subscription manually (free, trial, comp,
  // refund recovery, etc) instead of a real Lojou payment. Treated as
  // paid for access control, but EXCLUDED from MRR/revenue counts and
  // never gets a Transaction record. Prevents fake numbers in finance.
  grantedManually           Boolean   @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Affiliate program
  referredByCode     String?              // affiliate code that brought this user in
  affiliateAccount   AffiliateAccount?    // becomes an affiliate themselves
  affiliateReferrals AffiliateReferral[]  @relation("AffiliateReferralUser")

  // Coproducer attribution — set when a lead/user enters via /c/{code}.
  // Lets the system route renewals and remarketing back to the right
  // coproducer (and feeds the source filter in admin/finance).
  referredByCoproducer String?
  coproducerAccount    CoproducerAccount?

  leads              Lead[]
  lessonProgress     LessonProgress[]
  chatMessages       ChatMessage[]
  dispatchLogs       DispatchLog[]
  pushSubscriptions  PushSubscription[]
  scheduledDispatches ScheduledDispatch[]
}

model Lead {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  address   String?
  category  String
  location  String
  rating    Float?
  website   String?
  source    String   @default("google_maps")
  createdAt DateTime @default(now())

  @@index([userId])
}

model ScriptFolder {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  sortOrder Int      @default(0)
  scripts   Script[]
  createdAt DateTime @default(now())
}

model Script {
  id        String       @id @default(uuid())
  title     String
  content   String
  icon      String?
  sortOrder Int          @default(0)
  folderId  String
  folder    ScriptFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([folderId])
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(uuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  videoUrl    String
  duration    Int?     // seconds
  sortOrder   Int      @default(0)
  tools       Json?    // recommended tools
  content     String?  // lesson text content (markdown)
  materials   Json?    // [{name, url, type}] — links, PDFs, resources
  createdAt   DateTime @default(now())

  progress LessonProgress[]

  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
}

model Transaction {
  id            String   @id @default(uuid())
  orderId       String   @unique
  userEmail     String?
  userPhone     String?
  userName      String?
  // amount is always the TOTAL charged (principal + any order bumps).
  // Faturamento/MRR reports keep reading this field as-is.
  amount        Float
  currency      String   @default("MZN")
  status        String   // pending, approved, failed, refunded
  paymentMethod String?
  metadata      Json?
  // ── Gross + fee breakdown (audit) ─────────────────────────────────────
  // amount above is the NET we receive (after Lojou fee + coproducer split).
  // These columns let the admin see the full economic picture without
  // having to parse metadata payloads.
  grossAmount     Float?   // sum of product + bump prices the customer paid
  lojouFee        Float?   // platform fee deducted (10% × gross + 10 per item)
  coproducerFee   Float?   // coproducer split deducted (sharePct × principal)
  // ── Order bump audit fields ──────────────────────────────────────────
  orderBumpPid    String?  // e.g. "JQQWc" for Close Friends
  orderBumpAmount Float?   // bump amount only, so reports can split principal vs bump
  isCloseFriends  Boolean  @default(false)
  // True when the buyer was an existing user being reactivated/renewed,
  // false when this was their first paid order. Set by the webhook;
  // back-populated for historical rows via migration.
  isRenewal       Boolean  @default(false)
  // Coproducer attribution: set by the webhook when the order pid matches
  // a registered coproducer product, or when the buyer's User row carries
  // referredByCoproducer. NULL = principal (main product).
  coproducerId    String?
  coproducer      CoproducerAccount? @relation(fields: [coproducerId], references: [id])
  // Payment gateway that produced this transaction. Default 'lojou' for
  // historical rows. Values: 'lojou' | 'stripe' | 'manual'.
  gateway                 String   @default("lojou")
  stripePaymentIntentId   String?
  stripeInvoiceId         String?
  createdAt     DateTime @default(now())

  @@index([coproducerId])
}

model SystemConfig {
  id                       String  @id @default("singleton")
  maxUsers                 Int     @default(50)
  currentUsers             Int     @default(0)
  communityLink            String?
  mentoriaSchedule         String? // next mentoria ISO datetime
  mentoriaLink             String?
  komunikaVisitorFunnelId  String?
  komunikaCheckoutFunnelId String?
  komunikaAdminApiKey      String?
  komunikaInstanceId       String? // Komunika WhatsApp instance ID
  milestoneAlertPhone      String?
  milestoneAlertName       String?
}

model LandingConfig {
  id            String  @id @default("singleton")
  vslEmbedUrl   String? // legacy — simple URL
  vslEmbedHtml  String? // raw iframe HTML (Kilax, YouTube, etc)
  heroTitle     String?
  heroSubtitle  String?
  heroDesc      String?
  ctaText       String?
  priceAmount   Int     @default(797)
  maxVagas      Int     @default(50)
  sections      Json?   // full page sections as JSON
  headScripts       String? // Tracking pixels for <head> (concatenated)
  headScriptBlocks  String? // Tracking pixels as JSON array [{name, code}]
  bodyScripts       String? // Tracking pixels for <body>
  // Affiliate-specific overrides (used when the visitor lands via /r/{code})
  affiliateVslEmbedHtml  String?
  affiliateCreativesUrl  String?
  updatedAt         DateTime @updatedAt
}

model ScrapeJob {
  id        String   @id @default(uuid())
  userId    String
  query     String
  // Single-city legacy column (kept for backwards compat with old jobs).
  // New jobs populate `cities` (JSON array). The worker reads cities ??
  // [city] so both shapes resolve to a list.
  city      String
  cities    Json?    // string[] — multi-city support
  status    String   // processing, completed, failed
  leads     ScrapedLead[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model ScrapedLead {
  id          String   @id @default(uuid())
  jobId       String
  job         ScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  address     String?
  website     String?
  instagram   String?
  status      String   // "Sem Website", "Website Lento/Antigo", "Website Bom"
  recommendedScriptId String? // ID do script sugerido
  // Google Maps enrichment — captured by the worker from the Maps detail
  // page. mapsUrl is the canonical place link; placeId is the stable
  // identifier; rating/reviewsCount surface social proof in the UI.
  mapsUrl       String?
  placeId       String?
  rating        Float?
  reviewsCount  Int?
  latitude      Float?
  longitude     Float?
  // City that produced this lead (relevant when the job has multiple
  // cities — lets the UI/CSV show which city each lead came from).
  city          String?
  createdAt   DateTime @default(now())

  @@index([jobId])
}

model ChatMessage {
  id        String    @id @default(uuid())
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channel   String    // "community" or "support_{userId}"
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([channel, createdAt])
  @@index([senderId])
}

model DispatchLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String
  contactName String?
  message     String
  status      String   @default("sent") // sent, failed
  error       String?
  scheduleId  String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([scheduleId])
}

model ScheduledDispatch {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  status      String    @default("pending") // pending, running, completed, failed, cancelled
  payload     Json
  total       Int       @default(0)
  sent        Int       @default(0)
  failed      Int       @default(0)
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ═══════════════════════════════════════════
// AFFILIATE PROGRAM
// ═══════════════════════════════════════════

model AffiliateAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code          String   @unique               // 7–9 alphanumeric chars
  enabled       Boolean  @default(true)
  payoutMethod  String?                        // "mpesa" | "emola"
  payoutTarget  String?                        // phone number to receive funds
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referrals     AffiliateReferral[]
  commissions   AffiliateCommission[]
  withdrawals   AffiliateWithdrawal[]

  @@index([code])
}

model AffiliateReferral {
  id            String           @id @default(uuid())
  affiliateId   String
  affiliate     AffiliateAccount @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  email         String?
  phone         String?
  // Once the lead pays, link to the resulting user account
  userId        String?
  user          User?            @relation("AffiliateReferralUser", fields: [userId], references: [id], onDelete: SetNull)
  status        String           @default("pending") // pending | paid | refunded | lost_to_remarketing
  paidAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([affiliateId, status])
  @@index([email])
}

model AffiliateCommission {
  id            String           @id @default(uuid())
  affiliateId   String
  affiliate     AffiliateAccount @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referralId    String?
  lojouOrderId  String?
  saleAmount    Float
  grossAmount   Float            // commission before platform fee
  feeAmount     Float            // platform fee (10% of sale + fixed)
  netAmount     Float            // grossAmount - feeAmount (what's added to balance)
  availableAt   DateTime         // commission becomes withdrawable from this date (D+7)
  status        String           @default("pending") // pending | available | withdrawn | refunded
  withdrawalId  String?          // populated when included in a withdrawal payout
  createdAt     DateTime         @default(now())

  @@index([affiliateId, status])
  @@index([availableAt, status])
  @@index([withdrawalId])
}

model AffiliateWithdrawal {
  id              String           @id @default(uuid())
  affiliateId     String
  affiliate       AffiliateAccount @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amountRequested Float            // total gross (sum of net commissions consumed)
  feeAmount       Float            // 3% + 45 MZN
  amountNet       Float            // what the affiliate actually receives
  payoutMethod    String           // "mpesa" | "emola"
  payoutTarget    String
  status          String           @default("pending") // pending | paid | rejected
  notes           String?
  processedAt     DateTime?
  processedBy     String?          // admin user id who approved/rejected
  createdAt       DateTime         @default(now())

  @@index([affiliateId, status])
  @@index([status, createdAt])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  type          String   @default("percentage") // percentage, fixed
  value         Float
  maxUses       Int      @default(1)
  usesCount     Int      @default(0)
  active        Boolean  @default(true)
  lojouId       String?  // ID returned from Lojou after creation
  linkedUserId  String?  // optional: linked to specific user
  linkedUserEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlatformMilestone {
  id          String    @id @default(uuid())
  category    String    // "revenue" | "subscribers"
  targetValue Float
  reached     Boolean   @default(false)
  reachedAt   DateTime?
  notified    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([category, targetValue])
}

// ─────────────────────────────────────────────────────────
// Coproducer program
// ─────────────────────────────────────────────────────────
// A coproducer is a partner who sells the Código Zero offer under their
// own Lojou product pid. They get a personalised landing page at
// /c/{code}; every sale made through that page lands on their Lojou
// pid and is split by Lojou's own coproduction settings.
//
// The system uses `productPid` to back-attribute incoming webhooks
// (matches data.product.pid → CoproducerAccount.productPid). Leads
// captured on /c/{code} also persist `referredByCoproducer = code`
// on the User row as a secondary attribution signal.
//
// `sharePct` is documentation only — Lojou handles the actual split.
model CoproducerAccount {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Public code used in /c/{code} URLs. Short, copyable.
  code                String   @unique
  // Lojou product identifier owned by the coproducer. Webhook attribution
  // matches `data.product.pid` to this column.
  productPid          String   @unique
  // Optional plan id (Lojou)
  planId              String?
  // Public Lojou checkout fallback (https://pay.lojou.app/p/...)
  publicCheckoutUrl   String?
  // Coproducer's share of each sale (0-100). Lojou itself enforces the
  // split — this is shown in the coproducer dashboard for transparency.
  sharePct            Float    @default(50)
  // Order bump cadastrado por este coprodutor (opcional). Quando a Lojou
  // confirma um pedido contendo este pid, o webhook marca isCloseFriends
  // e estende a assinatura em +60 dias (mesma regra do bump principal).
  bumpProductPid      String?
  bumpPrice           Float?
  // Display name shown on dashboards / admin lists. Falls back to the
  // linked User.name when null.
  displayName         String?
  enabled             Boolean  @default(true)
  notes               String?

  // VSL embed (iframe HTML) que substitui o VSL principal na landing
  // /c/{code}. Só o superadmin edita — o coprodutor apenas visualiza.
  vslEmbedHtml        String?
  // Tags de rastreio (Meta Pixel, GA, TikTok etc.) que o coprodutor injeta
  // no <head> da própria landing /c/{code}. O coprodutor edita; superadmin
  // também pode editar/auditar.
  headScripts         String?

  transactions        Transaction[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([enabled])
}
