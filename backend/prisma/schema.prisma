generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  name               String
  email              String           @unique
  phone              String           @unique
  passwordHash       String
  role               String           @default("member") // member, admin
  isActive           Boolean          @default(true)
  subscriptionStatus String           @default("active") // active, grace_period, overdue, canceled
  subscriptionEnd    DateTime?
  lojouOrderId       String?
  checkoutUrl        String?
  lojouCustomerId    String?
  dailySearchCount   Int              @default(0)
  lastSearchDate     DateTime?
  komunikaApiKey     String?
  komunikaInstanceId String?
  remarketingStage   String           @default("none") // none, visitor_sent, checkout_failed_sent
  surveyAnswers      Json?
  avatarUrl          String?
  hasCompletedOnboarding Boolean @default(false)
  lastExpirationAlert DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  leads              Lead[]
  lessonProgress     LessonProgress[]
  chatMessages       ChatMessage[]
  dispatchLogs       DispatchLog[]
  pushSubscriptions  PushSubscription[]
}

model Lead {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  address   String?
  category  String
  location  String
  rating    Float?
  website   String?
  source    String   @default("google_maps")
  createdAt DateTime @default(now())

  @@index([userId])
}

model ScriptFolder {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  sortOrder Int      @default(0)
  scripts   Script[]
  createdAt DateTime @default(now())
}

model Script {
  id        String       @id @default(uuid())
  title     String
  content   String
  icon      String?
  sortOrder Int          @default(0)
  folderId  String
  folder    ScriptFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([folderId])
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(uuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  videoUrl    String
  duration    Int?     // seconds
  sortOrder   Int      @default(0)
  tools       Json?    // recommended tools
  content     String?  // lesson text content (markdown)
  materials   Json?    // [{name, url, type}] — links, PDFs, resources
  createdAt   DateTime @default(now())

  progress LessonProgress[]

  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
}

model Transaction {
  id            String   @id @default(uuid())
  orderId       String   @unique
  userEmail     String?
  userPhone     String?
  userName      String?
  amount        Float
  currency      String   @default("MZN")
  status        String   // pending, approved, failed, refunded
  paymentMethod String?
  metadata      Json?
  createdAt     DateTime @default(now())
}

model SystemConfig {
  id                       String  @id @default("singleton")
  maxUsers                 Int     @default(50)
  currentUsers             Int     @default(0)
  communityLink            String?
  mentoriaSchedule         String? // next mentoria ISO datetime
  mentoriaLink             String?
  komunikaVisitorFunnelId  String?
  komunikaCheckoutFunnelId String?
  komunikaAdminApiKey      String?
  komunikaInstanceId       String? // Komunika WhatsApp instance ID
  milestoneAlertPhone      String?
  milestoneAlertName       String?
}

model LandingConfig {
  id            String  @id @default("singleton")
  vslEmbedUrl   String? // legacy — simple URL
  vslEmbedHtml  String? // raw iframe HTML (Kilax, YouTube, etc)
  heroTitle     String?
  heroSubtitle  String?
  heroDesc      String?
  ctaText       String?
  priceAmount   Int     @default(797)
  maxVagas      Int     @default(50)
  sections      Json?   // full page sections as JSON
  headScripts   String? // Tracking pixels for <head>
  bodyScripts   String? // Tracking pixels for <body>
  updatedAt     DateTime @updatedAt
}

model ScrapeJob {
  id        String   @id @default(uuid())
  userId    String
  query     String
  city      String
  status    String   // processing, completed, failed
  leads     ScrapedLead[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model ScrapedLead {
  id          String   @id @default(uuid())
  jobId       String
  job         ScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  address     String?
  website     String?
  instagram   String?
  status      String   // "Sem Website", "Website Lento/Antigo", "Website Bom"
  recommendedScriptId String? // ID do script sugerido
  createdAt   DateTime @default(now())

  @@index([jobId])
}

model ChatMessage {
  id        String    @id @default(uuid())
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channel   String    // "community" or "support_{userId}"
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([channel, createdAt])
  @@index([senderId])
}

model DispatchLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String
  contactName String?
  message     String
  status      String   @default("sent") // sent, failed
  error       String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  type          String   @default("percentage") // percentage, fixed
  value         Float
  maxUses       Int      @default(1)
  usesCount     Int      @default(0)
  active        Boolean  @default(true)
  lojouId       String?  // ID returned from Lojou after creation
  linkedUserId  String?  // optional: linked to specific user
  linkedUserEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlatformMilestone {
  id          String    @id @default(uuid())
  category    String    // "revenue" | "subscribers"
  targetValue Float
  reached     Boolean   @default(false)
  reachedAt   DateTime?
  notified    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([category, targetValue])
}
