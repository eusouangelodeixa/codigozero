generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  name               String
  email              String           @unique
  phone              String           @unique
  passwordHash       String
  role               String           @default("member") // member, admin
  isActive           Boolean          @default(true)
  subscriptionStatus String           @default("active") // active, grace_period, overdue, canceled
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  renewalUrl         String?
  retentionCouponsUsed Int            @default(0)
  paymentsSinceLastCoupon Int         @default(0)
  lojouOrderId       String?
  checkoutUrl        String?
  lojouCustomerId    String?
  dailySearchCount   Int              @default(0)
  lastSearchDate     DateTime?
  komunikaApiKey     String?
  komunikaInstanceId String?
  remarketingStage   String           @default("none") // none → visitor_sent | none → checkout_pending → checkout_failed_sent
  surveyAnswers      Json?
  avatarUrl          String?
  hasCompletedOnboarding Boolean @default(false)
  lastExpirationAlert DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Affiliate program
  referredByCode     String?              // affiliate code that brought this user in
  affiliateAccount   AffiliateAccount?    // becomes an affiliate themselves
  affiliateReferrals AffiliateReferral[]  @relation("AffiliateReferralUser")

  leads              Lead[]
  lessonProgress     LessonProgress[]
  chatMessages       ChatMessage[]
  dispatchLogs       DispatchLog[]
  pushSubscriptions  PushSubscription[]
  scheduledDispatches ScheduledDispatch[]
}

model Lead {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  address   String?
  category  String
  location  String
  rating    Float?
  website   String?
  source    String   @default("google_maps")
  createdAt DateTime @default(now())

  @@index([userId])
}

model ScriptFolder {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  sortOrder Int      @default(0)
  scripts   Script[]
  createdAt DateTime @default(now())
}

model Script {
  id        String       @id @default(uuid())
  title     String
  content   String
  icon      String?
  sortOrder Int          @default(0)
  folderId  String
  folder    ScriptFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([folderId])
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(uuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  videoUrl    String
  duration    Int?     // seconds
  sortOrder   Int      @default(0)
  tools       Json?    // recommended tools
  content     String?  // lesson text content (markdown)
  materials   Json?    // [{name, url, type}] — links, PDFs, resources
  createdAt   DateTime @default(now())

  progress LessonProgress[]

  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
}

model Transaction {
  id            String   @id @default(uuid())
  orderId       String   @unique
  userEmail     String?
  userPhone     String?
  userName      String?
  amount        Float
  currency      String   @default("MZN")
  status        String   // pending, approved, failed, refunded
  paymentMethod String?
  metadata      Json?
  createdAt     DateTime @default(now())
}

model SystemConfig {
  id                       String  @id @default("singleton")
  maxUsers                 Int     @default(50)
  currentUsers             Int     @default(0)
  communityLink            String?
  mentoriaSchedule         String? // next mentoria ISO datetime
  mentoriaLink             String?
  komunikaVisitorFunnelId  String?
  komunikaCheckoutFunnelId String?
  komunikaAdminApiKey      String?
  komunikaInstanceId       String? // Komunika WhatsApp instance ID
  milestoneAlertPhone      String?
  milestoneAlertName       String?
}

model LandingConfig {
  id            String  @id @default("singleton")
  vslEmbedUrl   String? // legacy — simple URL
  vslEmbedHtml  String? // raw iframe HTML (Kilax, YouTube, etc)
  heroTitle     String?
  heroSubtitle  String?
  heroDesc      String?
  ctaText       String?
  priceAmount   Int     @default(797)
  maxVagas      Int     @default(50)
  sections      Json?   // full page sections as JSON
  headScripts       String? // Tracking pixels for <head> (concatenated)
  headScriptBlocks  String? // Tracking pixels as JSON array [{name, code}]
  bodyScripts       String? // Tracking pixels for <body>
  // Affiliate-specific overrides (used when the visitor lands via /r/{code})
  affiliateVslEmbedHtml  String?
  affiliateCreativesUrl  String?
  updatedAt         DateTime @updatedAt
}

model ScrapeJob {
  id        String   @id @default(uuid())
  userId    String
  query     String
  city      String
  status    String   // processing, completed, failed
  leads     ScrapedLead[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model ScrapedLead {
  id          String   @id @default(uuid())
  jobId       String
  job         ScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  address     String?
  website     String?
  instagram   String?
  status      String   // "Sem Website", "Website Lento/Antigo", "Website Bom"
  recommendedScriptId String? // ID do script sugerido
  createdAt   DateTime @default(now())

  @@index([jobId])
}

model ChatMessage {
  id        String    @id @default(uuid())
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  channel   String    // "community" or "support_{userId}"
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([channel, createdAt])
  @@index([senderId])
}

model DispatchLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String
  contactName String?
  message     String
  status      String   @default("sent") // sent, failed
  error       String?
  scheduleId  String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([scheduleId])
}

model ScheduledDispatch {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  status      String    @default("pending") // pending, running, completed, failed, cancelled
  payload     Json
  total       Int       @default(0)
  sent        Int       @default(0)
  failed      Int       @default(0)
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ═══════════════════════════════════════════
// AFFILIATE PROGRAM
// ═══════════════════════════════════════════

model AffiliateAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code          String   @unique               // 7–9 alphanumeric chars
  enabled       Boolean  @default(true)
  payoutMethod  String?                        // "mpesa" | "emola"
  payoutTarget  String?                        // phone number to receive funds
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referrals     AffiliateReferral[]
  commissions   AffiliateCommission[]
  withdrawals   AffiliateWithdrawal[]

  @@index([code])
}

model AffiliateReferral {
  id            String           @id @default(uuid())
  affiliateId   String
  affiliate     AffiliateAccount @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  email         String?
  phone         String?
  // Once the lead pays, link to the resulting user account
  userId        String?
  user          User?            @relation("AffiliateReferralUser", fields: [userId], references: [id], onDelete: SetNull)
  status        String           @default("pending") // pending | paid | refunded | lost_to_remarketing
  paidAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([affiliateId, status])
  @@index([email])
}

model AffiliateCommission {
  id            String           @id @default(uuid())
  affiliateId   String
  affiliate     AffiliateAccount @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referralId    String?
  lojouOrderId  String?
  saleAmount    Float
  grossAmount   Float            // commission before platform fee
  feeAmount     Float            // platform fee (10% of sale + fixed)
  netAmount     Float            // grossAmount - feeAmount (what's added to balance)
  availableAt   DateTime         // commission becomes withdrawable from this date (D+7)
  status        String           @default("pending") // pending | available | withdrawn | refunded
  withdrawalId  String?          // populated when included in a withdrawal payout
  createdAt     DateTime         @default(now())

  @@index([affiliateId, status])
  @@index([availableAt, status])
  @@index([withdrawalId])
}

model AffiliateWithdrawal {
  id              String           @id @default(uuid())
  affiliateId     String
  affiliate       AffiliateAccount @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amountRequested Float            // total gross (sum of net commissions consumed)
  feeAmount       Float            // 3% + 45 MZN
  amountNet       Float            // what the affiliate actually receives
  payoutMethod    String           // "mpesa" | "emola"
  payoutTarget    String
  status          String           @default("pending") // pending | paid | rejected
  notes           String?
  processedAt     DateTime?
  processedBy     String?          // admin user id who approved/rejected
  createdAt       DateTime         @default(now())

  @@index([affiliateId, status])
  @@index([status, createdAt])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  type          String   @default("percentage") // percentage, fixed
  value         Float
  maxUses       Int      @default(1)
  usesCount     Int      @default(0)
  active        Boolean  @default(true)
  lojouId       String?  // ID returned from Lojou after creation
  linkedUserId  String?  // optional: linked to specific user
  linkedUserEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlatformMilestone {
  id          String    @id @default(uuid())
  category    String    // "revenue" | "subscribers"
  targetValue Float
  reached     Boolean   @default(false)
  reachedAt   DateTime?
  notified    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([category, targetValue])
}
